# Groq API (free tier, OpenAI-compatible)
# Generate at: https://console.groq.com/keys

# Text / NLP calls (autopsy analysis, digital correlation)
GROQ_API_KEY=your-groq-text-key-here

# Vision calls (image → digital evidence extraction).
# Optional: if unset, GROQ_API_KEY is used for vision too.
GROQ_VISION_API_KEY=your-groq-vision-key-here

# Model overrides (optional)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_BASE_URL=https://api.groq.com/openai/v1
